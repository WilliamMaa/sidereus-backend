# DashScope 通义千问 API Key（必填）
DASHSCOPE_API_KEY=sk-xxxxxxxx

# 模型名称
QWEN_MODEL=qwen-plus

# Redis：本地 docker compose 用 redis://redis:6379/0
# FC 无 Redis 时设 CACHE_ENABLED=false（内存缓存）
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=false
CACHE_TTL_SECONDS=604800

# CORS，多个来源用逗号分隔；开发可设为 *
CORS_ORIGINS=*

# 服务端口（FC 固定 9000）
HOST=0.0.0.0
PORT=9000

# 部署地域：华北2（北京）cn-beijing，见 docs/DEPLOY.md
